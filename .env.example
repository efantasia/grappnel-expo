# Client (Expo) — EXPO_PUBLIC_* vars are inlined into the JS bundle at build
# time. Copy to .env and fill in from your Supabase project settings.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# To run against the local Supabase stack (`npm run supabase:start`), put the
# values from `npm run supabase:status` in a gitignored .env.local instead —
# Expo loads it with higher precedence than .env; delete it to switch back:
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY from supabase:status>

# --- Edge function secrets (NOT read by the app) ---------------------------
# Set these with:  npx supabase secrets set --env-file supabase/functions/.env
# For local `supabase functions serve`, put them in supabase/functions/.env
# (gitignored).
#
# GOOGLE_SERVICE_ACCOUNT_JSON  full JSON key for the grappnel service account
#                              (single line; output of scripts/setup-gcp.sh)
# GCP_PROJECT_ID               Google Cloud project id
# GCS_BUCKET                   materials content bucket, e.g. grappnel-materials
# VERTEX_SEARCH_LOCATION       global | us | eu   (default: global)
# VERTEX_SEARCH_DATASTORE_ID   e.g. grappnel-materials
# VERTEX_SEARCH_COLLECTION     default_collection (default)
# GEMINI_MODEL                 default: gemini-3.5-flash
# GEMINI_LOCATION              default: global
# GCP_TRANSCRIBE_JOB           Cloud Run transcription job name
#                              (default: grappnel-transcribe)
# GCP_TRANSCRIBE_REGION        Cloud Run job region (default: us-central1)
# YOUTUBE_PROXY_URL            optional rotating proxy for YouTube
#                              transcript fetches, e.g.
#                              http://user-rotate:pass@p.webshare.io:80 —
#                              needed because YouTube bot-walls datacenter
#                              IPs ("confirm you're not a bot"). Must be a
#                              RESIDENTIAL rotating plan (Webshare
#                              "Residential"); shared datacenter pools are
#                              already burned for YouTube (bot walls +
#                              caption-endpoint 429s). Only YouTube requests
#                              are proxied. A bare username gets "-rotate"
#                              appended automatically.
#
# The Modulate (Velma) API key is NOT a function secret — it lives in GCP
# Secret Manager and is only read by the Cloud Run job (see setup-gcp.sh).
