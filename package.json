{
  "name": "grappnel",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "build:web": "expo export --platform web",
    "topics:refresh": "node scripts/fetch-openalex-topics.mjs",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:restart": "npx supabase stop && npx supabase start",
    "supabase:status": "npx supabase status",
    "supabase:local:push": "npx supabase migration up --local",
    "supabase:functions": "npx supabase functions serve --env-file ./supabase/functions/.env",
    "deploy:db": "npx supabase db push",
    "deploy:functions": "npx supabase functions deploy",
    "deploy:transcribe": "CLOUDSDK_CONFIG=$HOME/.config/gcloud-personal gcloud run jobs deploy grappnel-transcribe --source gcp/transcribe-job --region us-central1 --project grappnel",
    "deploy:backend": "npm run deploy:db && npm run deploy:functions && npm run deploy:transcribe"
  },
  "dependencies": {
    "@expo/ui": "~57.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.0",
    "expo": "~57.0.2",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "lucide-react-native": "^1.23.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "supabase": "^2.109.1",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
